@model List<Appointment>
@{
    ViewData["Title"] = "Записи клиентов";
    var barbers = ViewBag.Barbers as List<Barber> ?? new();
    var statusMap = new Dictionary<string, (string label, string cls)>
    {
        ["Pending"]   = ("Ожидается",     "badge-pending"),
        ["Confirmed"] = ("Подтверждена",  "badge-confirmed"),
        ["Completed"] = ("Завершена",     "badge-completed"),
        ["Cancelled"] = ("Отменена",      "badge-cancelled"),
        ["NoShow"]    = ("Неявка",        "badge-noshow")
    };
}

<!-- Фильтры -->
<form method="get" class="admin-card p-3 mb-4">
    <div class="row g-3 align-items-end">
        <div class="col-md-3">
            <label class="bs-label">Статус</label>
            <select name="status" class="form-select bs-form-select form-select-sm">
                <option value="">Все статусы</option>
                @foreach (var s in statusMap)
                {
                    <option value="@s.Key" @(ViewBag.CurrentStatus == s.Key ? "selected" : "")>
                        @s.Value.label
                    </option>
                }
            </select>
        </div>
        <div class="col-md-3">
            <label class="bs-label">Дата</label>
            <input type="date" name="date" class="form-control bs-form-control form-control-sm"
                   value="@ViewBag.CurrentDate" />
        </div>
        <div class="col-md-3">
            <label class="bs-label">Мастер</label>
            <select name="barberId" class="form-select bs-form-select form-select-sm">
                <option value="">Все мастера</option>
                @foreach (var b in barbers)
                {
                    <option value="@b.Id" @(ViewBag.CurrentBarberId?.ToString() == b.Id.ToString() ? "selected" : "")>
                        @b.FullName
                    </option>
                }
            </select>
        </div>
        <div class="col-md-3 d-flex gap-2">
            <button type="submit" class="btn btn-sm bs-btn-gold flex-fill">Фильтр</button>
            <a asp-action="Index" class="btn btn-sm btn-outline-secondary">Сброс</a>
        </div>
    </div>
</form>

<div class="d-flex justify-content-between align-items-center mb-3">
    <h6 class="text-white mb-0">Найдено: @Model.Count</h6>
</div>

<div class="admin-card">
    <div class="table-responsive">
        <table class="table bs-table mb-0" style="font-size:.875rem">
            <thead>
                <tr>
                    <th>#</th>
                    <th>Клиент</th>
                    <th>Услуга</th>
                    <th>Мастер</th>
                    <th>Дата</th>
                    <th>Время</th>
                    <th>Сумма</th>
                    <th>Оплата</th>
                    <th>Статус</th>
                    <th></th>
                </tr>
            </thead>
            <tbody>
                @foreach (var a in Model)
                {
                    var statusKey = a.Status.ToString();
                    var (label, cls) = statusMap.TryGetValue(statusKey, out var v) ? v : (statusKey, "badge-noshow");
                    <tr>
                        <td class="text-muted">@a.Id</td>
                        <td>
                            <div class="text-white">@a.Client.FullName</div>
                            <div class="text-muted" style="font-size:.75rem">@a.Client.PhoneNumber</div>
                        </td>
                        <td class="text-muted">@a.Service.Name</td>
                        <td class="text-muted">@a.Barber.FullName</td>
                        <td class="text-muted">@a.AppointmentDate.ToString("dd.MM.yyyy")</td>
                        <td class="text-muted" style="white-space:nowrap">
                            @a.StartTime.ToString("HH:mm")–@a.EndTime.ToString("HH:mm")
                        </td>
                        <td class="text-gold">@a.TotalPrice.ToString("N0") ₽</td>
                        <td>
                            @if (a.Payment?.Status == PaymentStatus.Paid)
                            {
                                <span class="badge badge-completed rounded-pill px-2" style="font-size:.7rem">Оплачено</span>
                            }
                            else
                            {
                                <span class="badge badge-pending rounded-pill px-2" style="font-size:.7rem">Не оплачено</span>
                            }
                        </td>
                        <td>
                            <span class="badge rounded-pill px-2 @cls" style="font-size:.7rem">@label</span>
                        </td>
                        <td>
                            <a asp-action="Details" asp-route-id="@a.Id"
                               class="btn btn-sm btn-outline-secondary">
                                <i class="bi bi-eye"></i>
                            </a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
