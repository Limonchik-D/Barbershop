@model Barber
@{
    ViewData["Title"] = "Расписание мастера";
    var dayNames = new[] { "Воскресенье", "Понедельник", "Вторник", "Среда", "Четверг", "Пятница", "Суббота" };
    var workDays = Model.WorkDays.OrderBy(w => w.DayOfWeek).ToList();
    var schedules = Model.Schedules.OrderBy(s => s.Date).ToList();
}

<div class="d-flex align-items-center gap-3 mb-4">
    <a asp-action="Index" class="btn btn-sm btn-outline-secondary"><i class="bi bi-arrow-left"></i></a>
    <div>
        <h5 class="text-white mb-0">Расписание: @Model.FullName</h5>
        <div class="text-muted small">Настройка рабочего времени мастера</div>
    </div>
</div>

<div class="row g-4">
    <!-- Шаблон рабочей недели -->
    <div class="col-lg-7">
        <div class="admin-card p-4">
            <h6 class="text-gold mb-3"><i class="bi bi-calendar-week me-2"></i>Стандартное расписание</h6>
            <form asp-action="SaveWorkDays" method="post">
                <input type="hidden" name="barberId" value="@Model.Id" />
                @for (int i = 1; i <= 7; i++)
                {
                    var dow = (DayOfWeek)(i % 7);
                    var wd = workDays.FirstOrDefault(w => w.DayOfWeek == dow);
                    var idx = i - 1;
                    <div class="row g-2 align-items-center mb-3 p-2"
                         style="background:var(--bs-dark-card2);border-radius:8px">
                        <input type="hidden" name="workDays[@idx].DayOfWeek" value="@((int)dow)" />
                        <div class="col-3">
                            <div class="form-check">
                                <input class="form-check-input wd-check" type="checkbox"
                                       name="workDays[@idx].IsWorking" value="true"
                                       id="wd_@idx" @(wd?.IsWorking == true ? "checked" : "")
                                       onchange="toggleDay(this,@idx)" />
                                <input type="hidden" name="workDays[@idx].IsWorking" value="false" />
                                <label class="form-check-label text-white small fw-semibold" for="wd_@idx">
                                    @dayNames[(int)dow]
                                </label>
                            </div>
                        </div>
                        <div class="col-3">
                            <input type="time" name="workDays[@idx].StartTime"
                                   class="form-control bs-form-control form-control-sm wd-time-@idx"
                                   value="@(wd?.StartTime.ToString("HH:mm") ?? "10:00")"
                                   @(wd?.IsWorking != true ? "disabled" : "") />
                        </div>
                        <div class="col-3">
                            <input type="time" name="workDays[@idx].EndTime"
                                   class="form-control bs-form-control form-control-sm wd-time-@idx"
                                   value="@(wd?.EndTime.ToString("HH:mm") ?? "20:00")"
                                   @(wd?.IsWorking != true ? "disabled" : "") />
                        </div>
                        <div class="col-3">
                            <select name="workDays[@idx].SlotDurationMinutes"
                                    class="form-select bs-form-select form-select-sm wd-time-@idx"
                                    @(wd?.IsWorking != true ? "disabled" : "")>
                                @foreach (var min in new[] { 15, 20, 30, 45, 60 })
                                {
                                    <option value="@min" selected="@(wd?.SlotDurationMinutes == min)">Слот @min мин</option>
                                }
                            </select>
                        </div>
                    </div>
                }
                <button type="submit" class="btn bs-btn-gold mt-2 w-100">
                    <i class="bi bi-floppy me-2"></i>Сохранить расписание
                </button>
            </form>
        </div>
    </div>

    <!-- Особые дни -->
    <div class="col-lg-5">
        <div class="admin-card p-4 mb-3">
            <h6 class="text-gold mb-3"><i class="bi bi-calendar-x me-2"></i>Особый день</h6>
            <form asp-action="AddScheduleOverride" method="post">
                <input type="hidden" name="BarberId" value="@Model.Id" />
                <div class="mb-2">
                    <label class="bs-label">Дата</label>
                    <input type="date" name="Date" class="form-control bs-form-control"
                           min="@DateTime.Today.ToString("yyyy-MM-dd")" required />
                </div>
                <div class="mb-2">
                    <div class="form-check mb-2">
                        <input class="form-check-input" type="checkbox" id="isAvailableCheck"
                               name="IsAvailable" value="true" checked
                               onchange="toggleOverride(this)" />
                        <input type="hidden" name="IsAvailable" value="false" />
                        <label class="form-check-label text-muted small" for="isAvailableCheck">
                            Рабочий день
                        </label>
                    </div>
                </div>
                <div id="overrideTimeBlock" class="row g-2 mb-2">
                    <div class="col-6">
                        <label class="bs-label">Начало</label>
                        <input type="time" name="StartTime" class="form-control bs-form-control" value="10:00" />
                    </div>
                    <div class="col-6">
                        <label class="bs-label">Конец</label>
                        <input type="time" name="EndTime" class="form-control bs-form-control" value="20:00" />
                    </div>
                </div>
                <div class="mb-2">
                    <label class="bs-label">Примечание</label>
                    <input type="text" name="Note" class="form-control bs-form-control"
                           placeholder="Напр.: выходной, отпуск..." />
                </div>
                <button type="submit" class="btn bs-btn-gold w-100">
                    <i class="bi bi-plus-lg me-1"></i>Добавить
                </button>
            </form>
        </div>

        @if (schedules.Any())
        {
            <div class="admin-card p-3">
                <h6 class="text-gold mb-3">Особые дни (@schedules.Count)</h6>
                @foreach (var s in schedules.TakeLast(10))
                {
                    <div class="d-flex justify-content-between align-items-center py-2 border-bottom border-secondary">
                        <div>
                            <div class="text-white small">@s.Date.ToString("dd MMMM yyyy")</div>
                            @if (s.IsAvailable)
                            {
                                <div class="text-muted" style="font-size:.75rem">
                                    @s.StartTime.ToString("HH:mm") – @s.EndTime.ToString("HH:mm")
                                </div>
                            }
                            else
                            {
                                <div class="text-danger" style="font-size:.75rem">Выходной</div>
                            }
                            @if (!string.IsNullOrEmpty(s.Note))
                            {
                                <div class="text-muted" style="font-size:.7rem">@s.Note</div>
                            }
                        </div>
                        @if (s.IsAvailable)
                        {
                            <span class="badge badge-completed rounded-pill px-2" style="font-size:.65rem">Работает</span>
                        }
                        else
                        {
                            <span class="badge badge-cancelled rounded-pill px-2" style="font-size:.65rem">Выходной</span>
                        }
                    </div>
                }
            </div>
        }
    </div>
</div>

@section Scripts {
    <script>
        function toggleDay(cb, idx) {
            const disabled = !cb.checked;
            document.querySelectorAll('.wd-time-' + idx).forEach(el => el.disabled = disabled);
        }
        function toggleOverride(cb) {
            document.getElementById('overrideTimeBlock').style.display = cb.checked ? '' : 'none';
        }
    </script>
}
