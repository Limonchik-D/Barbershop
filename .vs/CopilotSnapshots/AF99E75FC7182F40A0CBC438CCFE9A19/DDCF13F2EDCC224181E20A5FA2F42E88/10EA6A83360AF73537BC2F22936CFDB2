<!DOCTYPE html>
<html lang="ru">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] — Панель управления</title>
    <script type="importmap"></script>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <style>
        :root { --admin-sidebar: #0d0e10; --admin-sidebar-width: 260px; }
        .admin-wrapper { display: flex; min-height: 100vh; }
        .admin-sidebar {
            width: var(--admin-sidebar-width); min-height: 100vh;
            background: var(--admin-sidebar); border-right: 1px solid var(--bs-dark-border);
            position: fixed; top: 0; left: 0; overflow-y: auto; z-index: 1000; display: flex; flex-direction: column;
        }
        .admin-sidebar-brand { padding: 1.25rem 1.5rem; border-bottom: 1px solid var(--bs-dark-border); }
        .admin-nav { padding: .75rem 0; flex: 1; }
        .admin-nav-section { padding: .4rem 1.5rem .2rem; font-size: .7rem; color: var(--bs-text-muted); text-transform: uppercase; letter-spacing: 2px; margin-top: .5rem; }
        .admin-nav-link {
            display: flex; align-items: center; gap: .75rem;
            padding: .55rem 1.5rem; color: #aaa; text-decoration: none;
            font-size: .9rem; transition: all .2s; border-left: 3px solid transparent;
        }
        .admin-nav-link:hover, .admin-nav-link.active {
            color: var(--bs-gold); background: rgba(201,169,110,.06);
            border-left-color: var(--bs-gold);
        }
        .admin-nav-link i { width: 18px; text-align: center; }
        .admin-content { margin-left: var(--admin-sidebar-width); flex: 1; display: flex; flex-direction: column; background: #16181c; }
        .admin-topbar {
            position: sticky; top: 0; z-index: 100;
            background: #13151a; border-bottom: 1px solid var(--bs-dark-border);
            padding: .75rem 1.5rem; display: flex; align-items: center; justify-content: space-between;
        }
        .admin-main { padding: 1.5rem; flex: 1; }
        .admin-card { background: var(--bs-dark-card); border: 1px solid var(--bs-dark-border); border-radius: 12px; }
        .stat-card { background: var(--bs-dark-card); border: 1px solid var(--bs-dark-border); border-radius: 12px; padding: 1.25rem; }
        .stat-card .stat-icon { width: 48px; height: 48px; border-radius: 10px; display: flex; align-items: center; justify-content: center; font-size: 1.4rem; }
        @@media (max-width: 768px) {
            .admin-sidebar { transform: translateX(-100%); transition: transform .3s; }
            .admin-sidebar.open { transform: translateX(0); }
            .admin-content { margin-left: 0; }
        }
    </style>
</head>
<body class="bs-body">
    <div class="admin-wrapper">
        <!-- Сайдбар -->
        <aside class="admin-sidebar" id="adminSidebar">
            <div class="admin-sidebar-brand">
                <a asp-area="" asp-controller="Home" asp-action="Index" class="text-decoration-none">
                    <span class="text-gold fw-bold fs-5"><i class="bi bi-scissors me-2"></i>BarberShop</span>
                </a>
                <div class="text-muted" style="font-size:.7rem;margin-top:.25rem">Панель управления</div>
            </div>
            <nav class="admin-nav">
                <div class="admin-nav-section">Главное</div>
                <a asp-area="Admin" asp-controller="Dashboard" asp-action="Index"
                   class="admin-nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Dashboard" ? "active" : "")">
                    <i class="bi bi-speedometer2"></i> Дашборд
                </a>

                <div class="admin-nav-section">Записи</div>
                <a asp-area="Admin" asp-controller="Appointments" asp-action="Index"
                   class="admin-nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Appointments" ? "active" : "")">
                    <i class="bi bi-calendar2-check"></i> Все записи
                </a>
                <a asp-area="Admin" asp-controller="Payments" asp-action="Index"
                   class="admin-nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Payments" ? "active" : "")">
                    <i class="bi bi-cash-coin"></i> Оплаты
                </a>

                <div class="admin-nav-section">Каталог</div>
                <a asp-area="Admin" asp-controller="Services" asp-action="Index"
                   class="admin-nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Services" ? "active" : "")">
                    <i class="bi bi-scissors"></i> Услуги
                </a>
                <a asp-area="Admin" asp-controller="Services" asp-action="Categories"
                   class="admin-nav-link">
                    <i class="bi bi-tags"></i> Категории
                </a>

                <div class="admin-nav-section">Команда</div>
                <a asp-area="Admin" asp-controller="Barbers" asp-action="Index"
                   class="admin-nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Barbers" ? "active" : "")">
                    <i class="bi bi-people"></i> Мастера
                </a>

                @if (User.IsInRole("Admin"))
                {
                    <div class="admin-nav-section">Система</div>
                    <a asp-area="Admin" asp-controller="Users" asp-action="Index"
                       class="admin-nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Users" ? "active" : "")">
                        <i class="bi bi-person-gear"></i> Пользователи
                    </a>
                }
            </nav>
            <div style="padding:1rem 1.5rem;border-top:1px solid var(--bs-dark-border)">
                <a asp-area="" asp-controller="Home" asp-action="Index" class="admin-nav-link ps-0">
                    <i class="bi bi-arrow-left-circle"></i> На сайт
                </a>
            </div>
        </aside>

        <!-- Контент -->
        <div class="admin-content">
            <div class="admin-topbar">
                <div class="d-flex align-items-center gap-3">
                    <button class="btn btn-sm btn-outline-secondary d-md-none" onclick="document.getElementById('adminSidebar').classList.toggle('open')">
                        <i class="bi bi-list"></i>
                    </button>
                    <h6 class="mb-0 text-white">@ViewData["Title"]</h6>
                </div>
                <div class="d-flex align-items-center gap-3">
                    <span class="text-muted small"><i class="bi bi-person-circle me-1"></i>@User.Identity?.Name</span>
                    <form asp-area="" asp-controller="Account" asp-action="Logout" method="post" class="mb-0">
                        <button type="submit" class="btn btn-sm btn-outline-danger">
                            <i class="bi bi-box-arrow-right"></i>
                        </button>
                    </form>
                </div>
            </div>

            <div class="admin-main">
                @if (TempData["Success"] != null)
                {
                    <div class="alert alert-success alert-dismissible fade show py-2 mb-3" role="alert">
                        <i class="bi bi-check-circle me-2"></i>@TempData["Success"]
                        <button type="button" class="btn-close btn-close-white" data-bs-dismiss="alert"></button>
                    </div>
                }
                @if (TempData["Error"] != null)
                {
                    <div class="alert alert-danger alert-dismissible fade show py-2 mb-3" role="alert">
                        <i class="bi bi-exclamation-triangle me-2"></i>@TempData["Error"]
                        <button type="button" class="btn-close btn-close-white" data-bs-dismiss="alert"></button>
                    </div>
                }
                @RenderBody()
            </div>
        </div>
    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
