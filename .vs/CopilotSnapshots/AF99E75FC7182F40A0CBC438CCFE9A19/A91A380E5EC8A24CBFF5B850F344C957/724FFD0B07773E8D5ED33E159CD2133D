/* ═══════════════════════════════════════════════════════════════════
   BarberShop — Global Styles
   Цветовая схема: тёмный фон + золото
═══════════════════════════════════════════════════════════════════ */

:root {
    --bs-gold: #c9a96e;
    --bs-gold-dark: #a8813f;
    --bs-dark-bg: #111214;
    --bs-dark-nav: #0d0e10;
    --bs-dark-card: #1a1c20;
    --bs-dark-card2: #22252b;
    --bs-dark-border: #2e3138;
    --bs-text-muted: #8a8f9a;
}

/* ─── Base ─────────────────────────────────────────── */
html { font-size: 16px; position: relative; min-height: 100%; }

.bs-body {
    background-color: var(--bs-dark-bg);
    color: #e0e0e0;
    font-family: 'Segoe UI', system-ui, sans-serif;
}

/* ─── Navbar ───────────────────────────────────────── */
.bs-navbar {
    background-color: var(--bs-dark-nav) !important;
    border-bottom: 1px solid var(--bs-dark-border);
    backdrop-filter: blur(8px);
}

.bs-navbar .navbar-brand { color: var(--bs-gold) !important; font-size: 1.4rem; letter-spacing: 1px; }
.bs-navbar .nav-link { color: #ccc !important; transition: color .2s; }
.bs-navbar .nav-link:hover { color: var(--bs-gold) !important; }
.bs-gold { color: var(--bs-gold) !important; }

/* ─── Main offset for fixed navbar ────────────────── */
.bs-main { padding-top: 72px; min-height: calc(100vh - 220px); }

/* ─── Buttons ──────────────────────────────────────── */
.bs-btn-gold {
    background-color: var(--bs-gold);
    border-color: var(--bs-gold);
    color: #111;
    font-weight: 600;
}
.bs-btn-gold:hover { background-color: var(--bs-gold-dark); border-color: var(--bs-gold-dark); color: #111; }
.bs-btn-outline-gold {
    border: 1px solid var(--bs-gold);
    color: var(--bs-gold);
    background: transparent;
}
.bs-btn-outline-gold:hover { background-color: var(--bs-gold); color: #111; }

/* ─── Cards ────────────────────────────────────────── */
.bs-card {
    background-color: var(--bs-dark-card);
    border: 1px solid var(--bs-dark-border);
    border-radius: 12px;
    transition: transform .25s, border-color .25s;
}
.bs-card:hover { transform: translateY(-4px); border-color: var(--bs-gold); }

/* ─── Hero ─────────────────────────────────────────── */
.bs-hero {
    min-height: 90vh;
    display: flex;
    align-items: center;
    background: linear-gradient(135deg, #0d0e10 0%, #1a1c20 60%, #2a2010 100%);
    position: relative;
    overflow: hidden;
}
.bs-hero::before {
    content: '';
    position: absolute; inset: 0;
    background: radial-gradient(ellipse at 70% 50%, rgba(201,169,110,.08) 0%, transparent 70%);
}
.bs-hero-title { font-size: clamp(2.5rem, 6vw, 4.5rem); font-weight: 800; line-height: 1.1; }
.bs-hero-title span { color: var(--bs-gold); }

/* ─── Section ──────────────────────────────────────── */
.bs-section { padding: 80px 0; }
.bs-section-title { font-size: 2rem; font-weight: 700; color: #fff; }
.bs-section-title span { color: var(--bs-gold); }
.bs-divider { width: 50px; height: 3px; background: var(--bs-gold); border-radius: 2px; }

/* ─── Service card ─────────────────────────────────── */
.bs-service-card { background: var(--bs-dark-card); border: 1px solid var(--bs-dark-border); border-radius: 12px; padding: 1.5rem; transition: all .25s; }
.bs-service-card:hover { border-color: var(--bs-gold); background: var(--bs-dark-card2); }
.bs-price { color: var(--bs-gold); font-size: 1.3rem; font-weight: 700; }
.bs-duration { color: var(--bs-text-muted); font-size: .85rem; }

/* ─── Barber card ──────────────────────────────────── */
.bs-barber-card { background: var(--bs-dark-card); border: 1px solid var(--bs-dark-border); border-radius: 12px; overflow: hidden; transition: all .25s; }
.bs-barber-card:hover { border-color: var(--bs-gold); transform: translateY(-4px); }
.bs-barber-avatar { width: 100%; height: 220px; object-fit: cover; background: var(--bs-dark-card2); display: flex; align-items: center; justify-content: center; }
.bs-barber-avatar-placeholder { width: 100%; height: 220px; background: var(--bs-dark-card2); display: flex; align-items: center; justify-content: center; font-size: 5rem; color: var(--bs-dark-border); }
.bs-stars { color: var(--bs-gold); letter-spacing: 2px; }

/* ─── Form ─────────────────────────────────────────── */
.bs-form-control {
    background-color: var(--bs-dark-card2) !important;
    border-color: var(--bs-dark-border) !important;
    color: #e0e0e0 !important;
    border-radius: 8px;
}
.bs-form-control:focus { border-color: var(--bs-gold) !important; box-shadow: 0 0 0 3px rgba(201,169,110,.15) !important; }
.bs-form-select { background-color: var(--bs-dark-card2) !important; border-color: var(--bs-dark-border) !important; color: #e0e0e0 !important; border-radius: 8px; }
.bs-form-select:focus { border-color: var(--bs-gold) !important; box-shadow: 0 0 0 3px rgba(201,169,110,.15) !important; }
.bs-label { color: #aaa; font-size: .875rem; margin-bottom: .35rem; }

/* ─── Auth pages ───────────────────────────────────── */
.bs-auth-wrapper { min-height: 100vh; display: flex; align-items: center; background: var(--bs-dark-bg); }
.bs-auth-card { background: var(--bs-dark-card); border: 1px solid var(--bs-dark-border); border-radius: 16px; padding: 2.5rem; width: 100%; max-width: 440px; }

/* ─── Status badges ────────────────────────────────── */
.badge-pending { background: #856404; color: #ffc107; }
.badge-confirmed { background: #055160; color: #0dcaf0; }
.badge-completed { background: #0a3622; color: #198754; }
.badge-cancelled { background: #58151c; color: #dc3545; }
.badge-noshow { background: #343a40; color: #6c757d; }

/* ─── Appointment card ─────────────────────────────── */
.bs-appt-card { background: var(--bs-dark-card); border: 1px solid var(--bs-dark-border); border-radius: 12px; padding: 1.25rem; margin-bottom: 1rem; transition: border-color .2s; }
.bs-appt-card:hover { border-color: var(--bs-gold); }

/* ─── Slot picker ──────────────────────────────────── */
.bs-slot { display: inline-block; padding: .4rem .8rem; border: 1px solid var(--bs-dark-border); border-radius: 6px; cursor: pointer; margin: .25rem; font-size: .875rem; color: #ccc; background: var(--bs-dark-card2); transition: all .2s; }
.bs-slot:hover, .bs-slot.selected { background: var(--bs-gold); color: #111; border-color: var(--bs-gold); font-weight: 600; }

/* ─── Footer ───────────────────────────────────────── */
.bs-footer { background-color: var(--bs-dark-nav); border-top: 1px solid var(--bs-dark-border); }

/* ─── Dropdown ─────────────────────────────────────── */
.bs-dropdown { background: var(--bs-dark-card); border: 1px solid var(--bs-dark-border); }
.bs-dropdown .dropdown-item { color: #ccc; }
.bs-dropdown .dropdown-item:hover { background: var(--bs-dark-card2); color: var(--bs-gold); }
.bs-dropdown hr { border-color: var(--bs-dark-border); }

/* ─── Table ────────────────────────────────────────── */
.bs-table { color: #e0e0e0; }
.bs-table thead { background: var(--bs-dark-card2); color: var(--bs-gold); }
.bs-table tbody tr { border-color: var(--bs-dark-border); }
.bs-table tbody tr:hover { background: rgba(201,169,110,.05); }

/* ─── Utilities ────────────────────────────────────── */
.text-gold { color: var(--bs-gold) !important; }
.border-gold { border-color: var(--bs-gold) !important; }
.bg-dark-card { background-color: var(--bs-dark-card) !important; }
.bg-dark-card2 { background-color: var(--bs-dark-card2) !important; }

