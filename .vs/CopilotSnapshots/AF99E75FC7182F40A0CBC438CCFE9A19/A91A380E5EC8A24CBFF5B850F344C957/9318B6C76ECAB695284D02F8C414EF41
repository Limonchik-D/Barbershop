@{
    ViewData["Title"] = "Главная";
    var categories = ViewBag.Categories as List<ServiceCategory> ?? new();
    var barbers = ViewBag.Barbers as List<Barber> ?? new();
    var reviews = ViewBag.Reviews as List<Review> ?? new();
}

<!-- ═══ HERO ═══════════════════════════════════════════════════ -->
<section class="bs-hero">
    <div class="container position-relative">
        <div class="row align-items-center">
            <div class="col-lg-7">
                <p class="text-gold fw-semibold mb-2 text-uppercase" style="letter-spacing:3px">Профессиональный уход</p>
                <h1 class="bs-hero-title text-white mb-4">
                    Твой стиль —<br><span>наше мастерство</span>
                </h1>
                <p class="text-muted mb-4 fs-5">Классические стрижки, горячее бритьё и безупречный уход за бородой.<br>Запишись онлайн — без очередей.</p>
                <div class="d-flex gap-3 flex-wrap">
                    @if (User.Identity?.IsAuthenticated == true)
                    {
                        <a asp-controller="Appointments" asp-action="Book" class="btn bs-btn-gold btn-lg px-4">
                            <i class="bi bi-calendar-plus me-2"></i>Записаться
                        </a>
                    }
                    else
                    {
                        <a asp-controller="Account" asp-action="Register" class="btn bs-btn-gold btn-lg px-4">
                            <i class="bi bi-calendar-plus me-2"></i>Записаться
                        </a>
                    }
                    <a asp-controller="Services" asp-action="Index" class="btn bs-btn-outline-gold btn-lg px-4">
                        Наши услуги
                    </a>
                </div>
                <div class="row mt-5 g-3">
                    <div class="col-4 text-center">
                        <div class="text-gold fw-bold fs-3">@barbers.Count+</div>
                        <div class="text-muted small">Мастеров</div>
                    </div>
                    <div class="col-4 text-center">
                        <div class="text-gold fw-bold fs-3">@categories.Sum(c => c.Services.Count)+</div>
                        <div class="text-muted small">Услуг</div>
                    </div>
                    <div class="col-4 text-center">
                        <div class="text-gold fw-bold fs-3">1000+</div>
                        <div class="text-muted small">Клиентов</div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- ═══ УСЛУГИ ══════════════════════════════════════════════════ -->
<section class="bs-section">
    <div class="container">
        <div class="text-center mb-5">
            <p class="text-gold text-uppercase small fw-semibold" style="letter-spacing:3px">Что мы предлагаем</p>
            <h2 class="bs-section-title">Наши <span>услуги</span></h2>
            <div class="bs-divider mx-auto mt-3"></div>
        </div>
        @foreach (var cat in categories)
        {
            <h5 class="text-gold mb-3 mt-4">@cat.Name</h5>
            <div class="row g-3 mb-3">
                @foreach (var svc in cat.Services.Take(4))
                {
                    <div class="col-md-6 col-lg-3">
                        <div class="bs-service-card h-100">
                            <h6 class="text-white mb-1">@svc.Name</h6>
                            <p class="text-muted small mb-3">@svc.Description</p>
                            <div class="d-flex justify-content-between align-items-center">
                                <span class="bs-price">@svc.Price.ToString("N0") ₽</span>
                                <span class="bs-duration"><i class="bi bi-clock me-1"></i>@svc.Duration мин</span>
                            </div>
                        </div>
                    </div>
                }
            </div>
        }
        <div class="text-center mt-4">
            <a asp-controller="Services" asp-action="Index" class="btn bs-btn-outline-gold">
                Все услуги <i class="bi bi-arrow-right ms-2"></i>
            </a>
        </div>
    </div>
</section>

<!-- ═══ КАК ЭТО РАБОТАЕТ ════════════════════════════════════════ -->
<section class="bs-section" style="background:var(--bs-dark-card)">
    <div class="container">
        <div class="text-center mb-5">
            <p class="text-gold text-uppercase small fw-semibold" style="letter-spacing:3px">Просто и быстро</p>
            <h2 class="bs-section-title">Как <span>записаться</span></h2>
            <div class="bs-divider mx-auto mt-3"></div>
        </div>
        <div class="row g-4 text-center">
            <div class="col-md-3">
                <div class="p-3">
                    <div class="mb-3 fs-1 text-gold"><i class="bi bi-person-plus"></i></div>
                    <div class="text-gold fw-bold mb-1" style="letter-spacing:3px;font-size:.75rem">01</div>
                    <h6 class="text-white">Зарегистрируйтесь</h6>
                    <p class="text-muted small">Создайте аккаунт за 1 минуту</p>
                </div>
            </div>
            <div class="col-md-3">
                <div class="p-3">
                    <div class="mb-3 fs-1 text-gold"><i class="bi bi-scissors"></i></div>
                    <div class="text-gold fw-bold mb-1" style="letter-spacing:3px;font-size:.75rem">02</div>
                    <h6 class="text-white">Выберите услугу</h6>
                    <p class="text-muted small">Выберите услугу и мастера</p>
                </div>
            </div>
            <div class="col-md-3">
                <div class="p-3">
                    <div class="mb-3 fs-1 text-gold"><i class="bi bi-calendar-check"></i></div>
                    <div class="text-gold fw-bold mb-1" style="letter-spacing:3px;font-size:.75rem">03</div>
                    <h6 class="text-white">Выберите время</h6>
                    <p class="text-muted small">Выберите дату и свободный слот</p>
                </div>
            </div>
            <div class="col-md-3">
                <div class="p-3">
                    <div class="mb-3 fs-1 text-gold"><i class="bi bi-check2-circle"></i></div>
                    <div class="text-gold fw-bold mb-1" style="letter-spacing:3px;font-size:.75rem">04</div>
                    <h6 class="text-white">Приходите</h6>
                    <p class="text-muted small">Ждём вас в назначенное время</p>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- ═══ МАСТЕРА ══════════════════════════════════════════════════ -->
@if (barbers.Any())
{
    <section class="bs-section">
        <div class="container">
            <div class="text-center mb-5">
                <p class="text-gold text-uppercase small fw-semibold" style="letter-spacing:3px">Профессионалы</p>
                <h2 class="bs-section-title">Наши <span>мастера</span></h2>
                <div class="bs-divider mx-auto mt-3"></div>
            </div>
            <div class="row g-4">
                @foreach (var barber in barbers)
                {
                    <div class="col-md-4">
                        <div class="bs-barber-card h-100">
                            @if (!string.IsNullOrEmpty(barber.PhotoUrl))
                            {
                                <img src="@barber.PhotoUrl" alt="@barber.FullName" class="bs-barber-avatar" />
                            }
                            else
                            {
                                <div class="bs-barber-avatar-placeholder"><i class="bi bi-person-circle"></i></div>
                            }
                            <div class="p-3">
                                <h5 class="text-white mb-1">@barber.DisplayName</h5>
                                <p class="text-gold small mb-2"><i class="bi bi-award me-1"></i>Стаж @barber.ExperienceYears лет</p>
                                <p class="text-muted small mb-3">@barber.Bio</p>
                                <a asp-controller="Barbers" asp-action="Details" asp-route-id="@barber.Id"
                                   class="btn bs-btn-outline-gold btn-sm w-100">Профиль и запись</a>
                            </div>
                        </div>
                    </div>
                }
            </div>
        </div>
    </section>
}

<!-- ═══ ОТЗЫВЫ ════════════════════════════════════════════════════ -->
@if (reviews.Any())
{
    <section class="bs-section" style="background:var(--bs-dark-card)">
        <div class="container">
            <div class="text-center mb-5">
                <p class="text-gold text-uppercase small fw-semibold" style="letter-spacing:3px">Мнения клиентов</p>
                <h2 class="bs-section-title">Что говорят <span>клиенты</span></h2>
                <div class="bs-divider mx-auto mt-3"></div>
            </div>
            <div class="row g-4">
                @foreach (var review in reviews)
                {
                    <div class="col-md-4">
                        <div class="bs-card p-4 h-100">
                            <div class="bs-stars mb-2">
                                @Html.Raw(string.Concat(Enumerable.Repeat("★", review.Rating)) + string.Concat(Enumerable.Repeat("☆", 5 - review.Rating)))
                            </div>
                            <p class="text-muted mb-3">"@review.Comment"</p>
                            <div class="d-flex align-items-center gap-2">
                                <div class="rounded-circle bg-dark-card2 d-flex align-items-center justify-content-center" style="width:40px;height:40px">
                                    <i class="bi bi-person text-gold"></i>
                                </div>
                                <div>
                                    <div class="text-white small fw-semibold">@review.Client.FullName</div>
                                    <div class="text-muted" style="font-size:.75rem">Мастер @review.Barber.DisplayName</div>
                                </div>
                            </div>
                        </div>
                    </div>
                }
            </div>
        </div>
    </section>
}

<!-- ═══ CTA ════════════════════════════════════════════════════════ -->
<section class="bs-section text-center" style="background:linear-gradient(135deg,#1a1c20,#2a2010)">
    <div class="container">
        <h2 class="bs-section-title mb-3">Готов обновить <span>образ?</span></h2>
        <p class="text-muted mb-4">Запишись онлайн прямо сейчас</p>
        @if (User.Identity?.IsAuthenticated == true)
        {
            <a asp-controller="Appointments" asp-action="Book" class="btn bs-btn-gold btn-lg px-5">
                <i class="bi bi-calendar-plus me-2"></i>Записаться
            </a>
        }
        else
        {
            <a asp-controller="Account" asp-action="Register" class="btn bs-btn-gold btn-lg px-5">
                <i class="bi bi-calendar-plus me-2"></i>Записаться сейчас
            </a>
        }
    </div>
</section>
