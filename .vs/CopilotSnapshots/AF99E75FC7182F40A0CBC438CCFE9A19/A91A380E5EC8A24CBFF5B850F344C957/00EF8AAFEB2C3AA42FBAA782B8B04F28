<!DOCTYPE html>
<html lang="ru">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] — BarberShop</title>
    <script type="importmap"></script>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body class="bs-body">

    <nav class="navbar navbar-expand-lg navbar-dark bs-navbar fixed-top">
        <div class="container">
            <a class="navbar-brand fw-bold" asp-controller="Home" asp-action="Index">
                <i class="bi bi-scissors me-2"></i>BarberShop
            </a>
            <button class="navbar-toggler border-0" type="button" data-bs-toggle="collapse" data-bs-target="#mainNav">
                <span class="navbar-toggler-icon"></span>
            </button>
            <div class="collapse navbar-collapse" id="mainNav">
                <ul class="navbar-nav me-auto">
                    <li class="nav-item">
                        <a class="nav-link" asp-controller="Home" asp-action="Index">Главная</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" asp-controller="Services" asp-action="Index">Услуги</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" asp-controller="Barbers" asp-action="Index">Мастера</a>
                    </li>
                    @if (User.Identity?.IsAuthenticated == true)
                    {
                        <li class="nav-item">
                            <a class="nav-link bs-gold" asp-controller="Appointments" asp-action="Book">
                                <i class="bi bi-calendar-plus me-1"></i>Записаться
                            </a>
                        </li>
                    }
                </ul>
                <ul class="navbar-nav ms-auto">
                    @if (User.Identity?.IsAuthenticated == true)
                    {
                        @if (User.IsInRole("Admin") || User.IsInRole("Manager"))
                        {
                            <li class="nav-item">
                                <a class="nav-link" asp-area="Admin" asp-controller="Dashboard" asp-action="Index">
                                    <i class="bi bi-speedometer2 me-1"></i>Панель
                                </a>
                            </li>
                        }
                        <li class="nav-item dropdown">
                            <a class="nav-link dropdown-toggle" href="#" data-bs-toggle="dropdown">
                                <i class="bi bi-person-circle me-1"></i>@User.Identity.Name
                            </a>
                            <ul class="dropdown-menu dropdown-menu-end bs-dropdown">
                                <li><a class="dropdown-item" asp-controller="Account" asp-action="MyAppointments">
                                    <i class="bi bi-calendar2-check me-2"></i>Мои записи</a></li>
                                <li><a class="dropdown-item" asp-controller="Account" asp-action="Profile">
                                    <i class="bi bi-gear me-2"></i>Профиль</a></li>
                                <li><hr class="dropdown-divider" /></li>
                                <li>
                                    <form asp-controller="Account" asp-action="Logout" method="post">
                                        <button type="submit" class="dropdown-item text-danger">
                                            <i class="bi bi-box-arrow-right me-2"></i>Выйти
                                        </button>
                                    </form>
                                </li>
                            </ul>
                        </li>
                    }
                    else
                    {
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Account" asp-action="Login">Войти</a>
                        </li>
                        <li class="nav-item ms-2">
                            <a class="btn bs-btn-gold btn-sm" asp-controller="Account" asp-action="Register">Регистрация</a>
                        </li>
                    }
                </ul>
            </div>
        </div>
    </nav>

    <main class="bs-main">
        @if (TempData["Success"] != null)
        {
            <div class="container pt-3">
                <div class="alert alert-success alert-dismissible fade show" role="alert">
                    <i class="bi bi-check-circle me-2"></i>@TempData["Success"]
                    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                </div>
            </div>
        }
        @if (TempData["Error"] != null)
        {
            <div class="container pt-3">
                <div class="alert alert-danger alert-dismissible fade show" role="alert">
                    <i class="bi bi-exclamation-triangle me-2"></i>@TempData["Error"]
                    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                </div>
            </div>
        }
        @RenderBody()
    </main>

    <footer class="bs-footer py-4 mt-5">
        <div class="container">
            <div class="row g-4">
                <div class="col-md-4">
                    <h5 class="bs-gold fw-bold"><i class="bi bi-scissors me-2"></i>BarberShop</h5>
                    <p class="text-muted small">Профессиональный барбершоп. Стрижки, бритьё и уход за бородой.</p>
                </div>
                <div class="col-md-4">
                    <h6 class="text-white">Навигация</h6>
                    <ul class="list-unstyled">
                        <li><a asp-controller="Services" asp-action="Index" class="text-muted text-decoration-none small">Услуги</a></li>
                        <li><a asp-controller="Barbers" asp-action="Index" class="text-muted text-decoration-none small">Мастера</a></li>
                        <li><a asp-controller="Appointments" asp-action="Book" class="text-muted text-decoration-none small">Запись</a></li>
                    </ul>
                </div>
                <div class="col-md-4">
                    <h6 class="text-white">Контакты</h6>
                    <p class="text-muted small mb-1"><i class="bi bi-geo-alt me-2"></i>ул. Примерная, д. 1</p>
                    <p class="text-muted small mb-1"><i class="bi bi-telephone me-2"></i>+7 (800) 000-00-00</p>
                    <p class="text-muted small"><i class="bi bi-clock me-2"></i>Пн–Пт: 10:00–20:00, Сб: 10:00–18:00</p>
                </div>
            </div>
            <hr class="border-secondary mt-3" />
            <p class="text-muted small text-center mb-0">&copy; @DateTime.Now.Year BarberShop. Все права защищены.</p>
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
