/* ═══════════════════════════════════════════════════════════════════
   BarberShop — Global Styles
   Цветовая схема: тёмный фон + золото
═══════════════════════════════════════════════════════════════════ */

:root {
    --bs-gold: #c9a96e;
    --bs-gold-dark: #a8813f;
    --bs-dark-bg: #111214;
    --bs-dark-nav: #0d0e10;
    --bs-dark-card: #1a1c20;
    --bs-dark-card2: #22252b;
    --bs-dark-border: #2e3138;
    --bs-text-muted: #8a8f9a;
}

/* ─── Bootstrap CSS-переменные: полное переопределение для тёмной темы ── */
.bs-body {
    /* Цветовая схема браузера (влияет на нативные элементы: scrollbar, date picker и т.д.) */
    color-scheme: dark;

    /* Текст */
    --bs-body-color:              #e0e0e0;
    --bs-body-color-rgb:          224, 224, 224;
    --bs-secondary-color:         #8a8f9a;   /* .text-muted */
    --bs-secondary-color-rgb:     138, 143, 154;
    --bs-tertiary-color:          rgba(224,224,224,.4);
    --bs-emphasis-color:          #fff;

    /* Фон */
    --bs-body-bg:                 #111214;
    --bs-body-bg-rgb:             17, 18, 20;
    --bs-secondary-bg:            #1a1c20;
    --bs-secondary-bg-rgb:        26, 28, 32;
    --bs-tertiary-bg:             #22252b;
    --bs-tertiary-bg-rgb:         34, 37, 43;

    /* Рамки */
    --bs-border-color:            #2e3138;
    --bs-border-color-translucent: rgba(255,255,255,.1);

    /* Ссылки */
    --bs-link-color:              #c9a96e;
    --bs-link-color-rgb:          201, 169, 110;
    --bs-link-hover-color:        #e0c080;
    --bs-link-decoration:         none;

    /* Карточки */
    --bs-card-bg:                 #1a1c20;
    --bs-card-border-color:       #2e3138;
    --bs-card-cap-bg:             rgba(255,255,255,.03);
    --bs-card-color:              #e0e0e0;

    /* Дропдаун */
    --bs-dropdown-bg:             #1a1c20;
    --bs-dropdown-border-color:   #2e3138;
    --bs-dropdown-divider-bg:     #2e3138;
    --bs-dropdown-link-color:     #ccc;
    --bs-dropdown-link-hover-bg:  #22252b;
    --bs-dropdown-link-hover-color: #c9a96e;
    --bs-dropdown-link-active-bg: #c9a96e;
    --bs-dropdown-link-active-color: #111;
    --bs-dropdown-header-color:   #8a8f9a;

    /* Инпуты */
    --bs-body-bg:                 #111214;
    --bs-input-bg:                #22252b;
    --bs-input-disabled-bg:       #1a1c20;
    --bs-input-disabled-border-color: #2e3138;
    --bs-input-color:             #e0e0e0;
    --bs-input-border-color:      #2e3138;
    --bs-input-focus-bg:          #22252b;
    --bs-input-focus-border-color: #c9a96e;
    --bs-input-focus-color:       #e0e0e0;
    --bs-input-placeholder-color: #8a8f9a;

    /* Таблицы */
    --bs-table-color:             #e0e0e0;
    --bs-table-bg:                transparent;
    --bs-table-border-color:      #2e3138;
    --bs-table-striped-bg:        rgba(255,255,255,.02);
    --bs-table-striped-color:     #e0e0e0;
    --bs-table-active-bg:         rgba(201,169,110,.05);
    --bs-table-active-color:      #e0e0e0;
    --bs-table-hover-bg:          rgba(201,169,110,.05);
    --bs-table-hover-color:       #e0e0e0;

    /* Навигация */
    --bs-nav-tabs-border-color:           #2e3138;
    --bs-nav-tabs-link-hover-border-color:#2e3138;
    --bs-nav-tabs-link-active-bg:         #1a1c20;
    --bs-nav-tabs-link-active-color:      #e0e0e0;
    --bs-nav-tabs-link-active-border-color:#2e3138;
    --bs-nav-link-color:          #ccc;
    --bs-nav-link-hover-color:    #c9a96e;

    /* Пагинация */
    --bs-pagination-color:        #ccc;
    --bs-pagination-bg:           #1a1c20;
    --bs-pagination-border-color: #2e3138;
    --bs-pagination-hover-color:  #c9a96e;
    --bs-pagination-hover-bg:     #22252b;
    --bs-pagination-hover-border-color:#2e3138;
    --bs-pagination-active-bg:    #c9a96e;
    --bs-pagination-active-border-color:#c9a96e;
    --bs-pagination-active-color: #111;
    --bs-pagination-disabled-color:#8a8f9a;
    --bs-pagination-disabled-bg:  #1a1c20;

    /* Модалки */
    --bs-modal-bg:                #1a1c20;
    --bs-modal-border-color:      #2e3138;
    --bs-modal-header-border-color:#2e3138;
    --bs-modal-footer-border-color:#2e3138;
    --bs-modal-content-bg:        #1a1c20;
    --bs-modal-content-color:     #e0e0e0;

    /* Тосты */
    --bs-toast-bg:                #22252b;
    --bs-toast-border-color:      #2e3138;
    --bs-toast-color:             #e0e0e0;
    --bs-toast-header-bg:         rgba(34,37,43,.85);
    --bs-toast-header-color:      #8a8f9a;

    /* Список */
    --bs-list-group-bg:           #1a1c20;
    --bs-list-group-border-color: #2e3138;
    --bs-list-group-color:        #e0e0e0;
    --bs-list-group-hover-bg:     #22252b;
    --bs-list-group-action-color: #ccc;
    --bs-list-group-action-hover-color:#c9a96e;
    --bs-list-group-action-active-bg:#22252b;
    --bs-list-group-action-active-color:#e0e0e0;
    --bs-list-group-active-bg:    #c9a96e;
    --bs-list-group-active-border-color:#c9a96e;
    --bs-list-group-active-color: #111;

    /* Кнопка закрытия (×) */
    --bs-btn-close-color:         #e0e0e0;
    --bs-btn-close-opacity:       0.8;
    --bs-btn-close-hover-opacity: 1;

    /* Progress */
    --bs-progress-bg:             #22252b;
    --bs-progress-bar-bg:         #c9a96e;

    /* Tooltip */
    --bs-tooltip-bg:              #c9a96e;
    --bs-tooltip-color:           #111;

    /* Popover */
    --bs-popover-bg:              #1a1c20;
    --bs-popover-border-color:    #2e3138;
    --bs-popover-body-color:      #e0e0e0;
    --bs-popover-header-bg:       #22252b;
    --bs-popover-header-color:    #c9a96e;

    /* Код */
    --bs-code-color:              #c9a96e;
    --bs-pre-color:               #e0e0e0;
}

/* ─── Компонентные переопределения ──────────────────── */

/* Форма — глобально (не только .bs-form-control) */
.form-control, .form-select {
    background-color: var(--bs-dark-card2);
    border-color: var(--bs-dark-border);
    color: #e0e0e0;
}
.form-control:focus, .form-select:focus {
    background-color: var(--bs-dark-card2);
    border-color: var(--bs-gold);
    color: #e0e0e0;
    box-shadow: 0 0 0 3px rgba(201,169,110,.15);
}
.form-control::placeholder { color: #8a8f9a; }
.form-control:disabled, .form-select:disabled {
    background-color: var(--bs-dark-card);
    color: #8a8f9a;
}

/* Стрелка select на тёмном фоне */
.form-select {
    background-image: url("data:image/svg+xml,%3csvg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 16 16'%3e%3cpath fill='none' stroke='%238a8f9a' stroke-linecap='round' stroke-linejoin='round' stroke-width='2' d='M2 5l6 6 6-6'/%3e%3c/svg%3e");
}

/* Checkbox / Radio */
.form-check-input {
    background-color: var(--bs-dark-card2);
    border-color: #555;
}
.form-check-input:checked {
    background-color: var(--bs-gold);
    border-color: var(--bs-gold);
}
.form-check-input:focus {
    border-color: var(--bs-gold);
    box-shadow: 0 0 0 3px rgba(201,169,110,.15);
}
.form-check-label { color: #ccc; }

/* Input[type=date|time] — нативная иконка и текст */
input[type="date"], input[type="time"], input[type="datetime-local"] {
    color-scheme: dark;
}

/* Textarea */
textarea.form-control { resize: vertical; }

/* Кнопка ✕ в алертах (Bootstrap использует SVG-иконку) */
.btn-close {
    filter: invert(1) grayscale(1) brightness(1.5);
}

/* Дропдаун */
.dropdown-menu {
    background-color: var(--bs-dark-card);
    border-color: var(--bs-dark-border);
}
.dropdown-item { color: #ccc; }
.dropdown-item:hover, .dropdown-item:focus {
    background-color: var(--bs-dark-card2);
    color: var(--bs-gold);
}
.dropdown-item.active, .dropdown-item:active {
    background-color: var(--bs-gold);
    color: #111;
}
.dropdown-divider { border-color: var(--bs-dark-border); }
.dropdown-header { color: #8a8f9a; }

/* Алерты */
.alert { border: 1px solid; }
.alert-success {
    background-color: rgba(25,135,84,.15);
    border-color: rgba(25,135,84,.4);
    color: #75e2a0;
}
.alert-danger {
    background-color: rgba(220,53,69,.15);
    border-color: rgba(220,53,69,.4);
    color: #f07070;
}
.alert-warning {
    background-color: rgba(255,193,7,.1);
    border-color: rgba(255,193,7,.3);
    color: #ffd553;
}
.alert-info {
    background-color: rgba(13,202,240,.1);
    border-color: rgba(13,202,240,.3);
    color: #5edff5;
}

/* Карточка Bootstrap */
.card {
    background-color: var(--bs-dark-card);
    border-color: var(--bs-dark-border);
    color: #e0e0e0;
}
.card-header, .card-footer {
    background-color: rgba(255,255,255,.03);
    border-color: var(--bs-dark-border);
    color: #e0e0e0;
}

/* Таблица Bootstrap */
.table { color: #e0e0e0; border-color: var(--bs-dark-border); }
.table > :not(caption) > * > * { background-color: transparent; border-bottom-color: var(--bs-dark-border); }
.table-hover > tbody > tr:hover > * { background-color: rgba(201,169,110,.05); }

/* Горизонтальная линия */
hr { border-color: var(--bs-dark-border); opacity: .5; }

/* Breadcrumb */
.breadcrumb-item + .breadcrumb-item::before { color: #8a8f9a; }
.breadcrumb-item.active { color: #8a8f9a; }
.breadcrumb-item a { color: var(--bs-gold); }

/* Validation summary */
.validation-summary-errors { color: #f07070; }
.field-validation-error { color: #f07070; font-size: .8rem; }
.input-validation-error {
    border-color: #dc3545 !important;
    background-color: var(--bs-dark-card2) !important;
}

/* ─── Base ─────────────────────────────────────────── */
html { font-size: 16px; position: relative; min-height: 100%; }

.bs-body {
    background-color: var(--bs-dark-bg);
    color: #e0e0e0;
    font-family: 'Segoe UI', system-ui, sans-serif;
}

/* ─── Navbar ───────────────────────────────────────── */
.bs-navbar {
    background-color: var(--bs-dark-nav) !important;
    border-bottom: 1px solid var(--bs-dark-border);
    backdrop-filter: blur(8px);
}

.bs-navbar .navbar-brand { color: var(--bs-gold) !important; font-size: 1.4rem; letter-spacing: 1px; }
.bs-navbar .nav-link { color: #ccc !important; transition: color .2s; }
.bs-navbar .nav-link:hover { color: var(--bs-gold) !important; }
.bs-gold { color: var(--bs-gold) !important; }

/* ─── Main offset for fixed navbar ────────────────── */
.bs-main { padding-top: 72px; min-height: calc(100vh - 220px); }

/* ─── Buttons ──────────────────────────────────────── */
.bs-btn-gold {
    background-color: var(--bs-gold);
    border-color: var(--bs-gold);
    color: #111;
    font-weight: 600;
}
.bs-btn-gold:hover { background-color: var(--bs-gold-dark); border-color: var(--bs-gold-dark); color: #111; }
.bs-btn-outline-gold {
    border: 1px solid var(--bs-gold);
    color: var(--bs-gold);
    background: transparent;
}
.bs-btn-outline-gold:hover { background-color: var(--bs-gold); color: #111; }

/* ─── Cards ────────────────────────────────────────── */
.bs-card {
    background-color: var(--bs-dark-card);
    border: 1px solid var(--bs-dark-border);
    border-radius: 12px;
    transition: transform .25s, border-color .25s;
}
.bs-card:hover { transform: translateY(-4px); border-color: var(--bs-gold); }

/* ─── Hero ─────────────────────────────────────────── */
.bs-hero {
    min-height: 90vh;
    display: flex;
    align-items: center;
    background: linear-gradient(135deg, #0d0e10 0%, #1a1c20 60%, #2a2010 100%);
    position: relative;
    overflow: hidden;
}
.bs-hero::before {
    content: '';
    position: absolute; inset: 0;
    background: radial-gradient(ellipse at 70% 50%, rgba(201,169,110,.08) 0%, transparent 70%);
}
.bs-hero-title { font-size: clamp(2.5rem, 6vw, 4.5rem); font-weight: 800; line-height: 1.1; }
.bs-hero-title span { color: var(--bs-gold); }

/* ─── Section ──────────────────────────────────────── */
.bs-section { padding: 80px 0; }
.bs-section-title { font-size: 2rem; font-weight: 700; color: #fff; }
.bs-section-title span { color: var(--bs-gold); }
.bs-divider { width: 50px; height: 3px; background: var(--bs-gold); border-radius: 2px; }

/* ─── Service card ─────────────────────────────────── */
.bs-service-card { background: var(--bs-dark-card); border: 1px solid var(--bs-dark-border); border-radius: 12px; padding: 1.5rem; transition: all .25s; }
.bs-service-card:hover { border-color: var(--bs-gold); background: var(--bs-dark-card2); }
.bs-price { color: var(--bs-gold); font-size: 1.3rem; font-weight: 700; }
.bs-duration { color: var(--bs-text-muted); font-size: .85rem; }

/* ─── Barber card ──────────────────────────────────── */
.bs-barber-card { background: var(--bs-dark-card); border: 1px solid var(--bs-dark-border); border-radius: 12px; overflow: hidden; transition: all .25s; }
.bs-barber-card:hover { border-color: var(--bs-gold); transform: translateY(-4px); }
.bs-barber-avatar { width: 100%; height: 220px; object-fit: cover; }
.bs-barber-avatar-placeholder { width: 100%; height: 220px; background: var(--bs-dark-card2); display: flex; align-items: center; justify-content: center; font-size: 5rem; color: var(--bs-dark-border); }
.bs-stars { color: var(--bs-gold); letter-spacing: 2px; }

/* ─── Form custom classes ──────────────────────────── */
.bs-form-control {
    background-color: var(--bs-dark-card2) !important;
    border-color: var(--bs-dark-border) !important;
    color: #e0e0e0 !important;
    border-radius: 8px;
}
.bs-form-control:focus { border-color: var(--bs-gold) !important; box-shadow: 0 0 0 3px rgba(201,169,110,.15) !important; }
.bs-form-select {
    background-color: var(--bs-dark-card2) !important;
    border-color: var(--bs-dark-border) !important;
    color: #e0e0e0 !important;
    border-radius: 8px;
    background-image: url("data:image/svg+xml,%3csvg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 16 16'%3e%3cpath fill='none' stroke='%238a8f9a' stroke-linecap='round' stroke-linejoin='round' stroke-width='2' d='M2 5l6 6 6-6'/%3e%3c/svg%3e") !important;
}
.bs-form-select:focus { border-color: var(--bs-gold) !important; box-shadow: 0 0 0 3px rgba(201,169,110,.15) !important; }
.bs-label { color: #aaa; font-size: .875rem; margin-bottom: .35rem; display: block; }

/* ─── Auth pages ───────────────────────────────────── */
.bs-auth-wrapper { min-height: 100vh; display: flex; align-items: center; background: var(--bs-dark-bg); }
.bs-auth-card { background: var(--bs-dark-card); border: 1px solid var(--bs-dark-border); border-radius: 16px; padding: 2.5rem; width: 100%; max-width: 440px; }

/* ─── Status badges ────────────────────────────────── */
.badge-pending   { background: rgba(133,100,4,.4);   color: #ffc107; border: 1px solid rgba(255,193,7,.3); }
.badge-confirmed { background: rgba(5,81,96,.4);     color: #0dcaf0; border: 1px solid rgba(13,202,240,.3); }
.badge-completed { background: rgba(10,54,34,.4);    color: #2ecc71; border: 1px solid rgba(25,135,84,.3); }
.badge-cancelled { background: rgba(88,21,28,.4);    color: #f07070; border: 1px solid rgba(220,53,69,.3); }
.badge-noshow    { background: rgba(52,58,64,.4);    color: #adb5bd; border: 1px solid rgba(108,117,125,.3); }

/* ─── Appointment card ─────────────────────────────── */
.bs-appt-card { background: var(--bs-dark-card); border: 1px solid var(--bs-dark-border); border-radius: 12px; padding: 1.25rem; margin-bottom: 1rem; transition: border-color .2s; }
.bs-appt-card:hover { border-color: var(--bs-gold); }

/* ─── Slot picker ──────────────────────────────────── */
.bs-slot { display: inline-block; padding: .4rem .8rem; border: 1px solid var(--bs-dark-border); border-radius: 6px; cursor: pointer; margin: .25rem; font-size: .875rem; color: #ccc; background: var(--bs-dark-card2); transition: all .2s; }
.bs-slot:hover, .bs-slot.selected { background: var(--bs-gold); color: #111; border-color: var(--bs-gold); font-weight: 600; }

/* ─── Footer ───────────────────────────────────────── */
.bs-footer { background-color: var(--bs-dark-nav); border-top: 1px solid var(--bs-dark-border); }

/* ─── Dropdown custom ──────────────────────────────── */
.bs-dropdown { background: var(--bs-dark-card); border: 1px solid var(--bs-dark-border); }
.bs-dropdown .dropdown-item { color: #ccc; }
.bs-dropdown .dropdown-item:hover { background: var(--bs-dark-card2); color: var(--bs-gold); }

/* ─── Table custom ─────────────────────────────────── */
.bs-table { color: #e0e0e0; }
.bs-table thead { background: var(--bs-dark-card2); color: var(--bs-gold); }
.bs-table tbody tr { border-color: var(--bs-dark-border); }
.bs-table tbody tr:hover { background: rgba(201,169,110,.05); }

/* ─── Utilities ────────────────────────────────────── */
.text-gold { color: var(--bs-gold) !important; }
.border-gold { border-color: var(--bs-gold) !important; }
.bg-dark-card { background-color: var(--bs-dark-card) !important; }
.bg-dark-card2 { background-color: var(--bs-dark-card2) !important; }


