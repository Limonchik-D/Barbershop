@model Barber
@{
    ViewData["Title"] = Model.FullName;
    var avgRating = (double)ViewBag.AverageRating;
}

<div class="container py-5">
    <div class="row g-5">
        <!-- Профиль мастера -->
        <div class="col-md-4">
            <div class="bs-barber-card">
                @if (!string.IsNullOrEmpty(Model.PhotoUrl))
                {
                    <img src="@Model.PhotoUrl" alt="@Model.FullName" class="bs-barber-avatar" />
                }
                else
                {
                    <div class="bs-barber-avatar-placeholder" style="height:280px"><i class="bi bi-person-circle"></i></div>
                }
                <div class="p-4">
                    <h4 class="text-white mb-1">@Model.DisplayName</h4>
                    <p class="text-gold mb-2"><i class="bi bi-award me-1"></i>Стаж @Model.ExperienceYears лет</p>
                    @if (avgRating > 0)
                    {
                        <div class="d-flex align-items-center gap-2 mb-2">
                            <div class="bs-stars">@string.Concat(Enumerable.Repeat("★", (int)Math.Round(avgRating)))</div>
                            <span class="text-muted small">@avgRating.ToString("F1") / 5</span>
                        </div>
                    }
                    @if (!string.IsNullOrEmpty(Model.Phone))
                    {
                        <p class="text-muted small mb-1"><i class="bi bi-telephone me-2"></i>@Model.Phone</p>
                    }
                    @if (!string.IsNullOrEmpty(Model.Email))
                    {
                        <p class="text-muted small mb-3"><i class="bi bi-envelope me-2"></i>@Model.Email</p>
                    }
                    <p class="text-muted">@Model.Bio</p>

                    @if (User.Identity?.IsAuthenticated == true)
                    {
                        <a asp-controller="Appointments" asp-action="Book" asp-route-barberId="@Model.Id"
                           class="btn bs-btn-gold w-100 mt-2">
                            <i class="bi bi-calendar-plus me-2"></i>Записаться к этому мастеру
                        </a>
                    }
                    else
                    {
                        <a asp-controller="Account" asp-action="Register"
                           class="btn bs-btn-gold w-100 mt-2">
                            <i class="bi bi-calendar-plus me-2"></i>Записаться
                        </a>
                    }
                </div>
            </div>
        </div>

        <!-- Услуги и отзывы -->
        <div class="col-md-8">
            <h5 class="text-gold mb-3">Услуги мастера</h5>
            <div class="row g-3 mb-5">
                @foreach (var bs in Model.BarberServices)
                {
                    <div class="col-md-6">
                        <div class="bs-service-card">
                            <h6 class="text-white mb-1">@bs.Service.Name</h6>
                            <p class="text-muted small mb-2">@bs.Service.Category?.Name</p>
                            <div class="d-flex justify-content-between">
                                <span class="bs-price">@bs.Service.Price.ToString("N0") ₽</span>
                                <span class="bs-duration"><i class="bi bi-clock me-1"></i>@bs.Service.Duration мин</span>
                            </div>
                        </div>
                    </div>
                }
            </div>

            @if (Model.Reviews.Any())
            {
                <h5 class="text-gold mb-3">Отзывы (@Model.Reviews.Count)</h5>
                @foreach (var review in Model.Reviews)
                {
                    <div class="bs-card p-3 mb-3">
                        <div class="d-flex justify-content-between align-items-start mb-2">
                            <div class="d-flex align-items-center gap-2">
                                <div class="rounded-circle bg-dark-card2 d-flex align-items-center justify-content-center" style="width:36px;height:36px">
                                    <i class="bi bi-person text-gold"></i>
                                </div>
                                <span class="text-white small fw-semibold">@review.Client.FullName</span>
                            </div>
                            <div class="bs-stars" style="font-size:.9rem">@string.Concat(Enumerable.Repeat("★", review.Rating))</div>
                        </div>
                        <p class="text-muted small mb-1">@review.Comment</p>
                        <div class="text-muted" style="font-size:.75rem">@review.CreatedAt.ToString("dd.MM.yyyy")</div>
                    </div>
                }
            }
            else
            {
                <p class="text-muted">Отзывов пока нет</p>
            }
        </div>
    </div>
</div>
