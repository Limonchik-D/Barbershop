@model List<ServiceCategory>
@{
    ViewData["Title"] = "Услуги";
}

<div class="container py-5">
    <div class="text-center mb-5">
        <p class="text-gold text-uppercase small fw-semibold" style="letter-spacing:3px">Прайс-лист</p>
        <h2 class="bs-section-title">Наши <span>услуги</span></h2>
        <div class="bs-divider mx-auto mt-3"></div>
    </div>

    @foreach (var cat in Model)
    {
        <div class="mb-5">
            <h4 class="text-gold border-bottom border-secondary pb-2 mb-4">
                <i class="bi bi-chevron-right me-2" style="font-size:.8rem"></i>@cat.Name
            </h4>
            @if (!string.IsNullOrEmpty(cat.Description))
            {
                <p class="text-muted mb-3">@cat.Description</p>
            }
            <div class="row g-3">
                @foreach (var svc in cat.Services)
                {
                    <div class="col-md-6 col-lg-4">
                        <div class="bs-service-card h-100">
                            <h6 class="text-white mb-1">@svc.Name</h6>
                            <p class="text-muted small mb-3">@svc.Description</p>
                            <div class="d-flex justify-content-between align-items-center mb-3">
                                <span class="bs-price">@svc.Price.ToString("N0") ₽</span>
                                <span class="bs-duration"><i class="bi bi-clock me-1"></i>@svc.Duration мин</span>
                            </div>
                            @if (User.Identity?.IsAuthenticated == true)
                            {
                                <a asp-controller="Appointments" asp-action="Book"
                                   asp-route-serviceId="@svc.Id"
                                   class="btn bs-btn-outline-gold btn-sm w-100">Записаться</a>
                            }
                            else
                            {
                                <a asp-controller="Account" asp-action="Register"
                                   class="btn bs-btn-outline-gold btn-sm w-100">Записаться</a>
                            }
                        </div>
                    </div>
                }
            </div>
        </div>
    }
</div>
