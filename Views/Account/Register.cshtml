@model RegisterViewModel
@{
    ViewData["Title"] = "Регистрация";
    Layout = null;
}
<!DOCTYPE html>
<html lang="ru">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Регистрация — BarberShop</title>
    <script type="importmap"></script>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body class="bs-body bs-auth-wrapper">
    <div class="container d-flex justify-content-center align-items-center py-5" style="min-height:100vh">
        <div class="bs-auth-card" style="max-width:500px">
            <div class="text-center mb-4">
                <a asp-controller="Home" asp-action="Index" class="text-decoration-none">
                    <h3 class="text-gold fw-bold"><i class="bi bi-scissors me-2"></i>BarberShop</h3>
                </a>
                <p class="text-muted mt-1">Создайте аккаунт</p>
            </div>

            <form asp-action="Register" method="post">
                <div asp-validation-summary="ModelOnly" class="alert alert-danger py-2 small"></div>

                <div class="row g-3 mb-3">
                    <div class="col-6">
                        <label asp-for="FirstName" class="bs-label"></label>
                        <input asp-for="FirstName" class="form-control bs-form-control" placeholder="Иван" />
                        <span asp-validation-for="FirstName" class="text-danger small"></span>
                    </div>
                    <div class="col-6">
                        <label asp-for="LastName" class="bs-label"></label>
                        <input asp-for="LastName" class="form-control bs-form-control" placeholder="Иванов" />
                        <span asp-validation-for="LastName" class="text-danger small"></span>
                    </div>
                </div>
                <div class="mb-3">
                    <label asp-for="Email" class="bs-label"></label>
                    <input asp-for="Email" class="form-control bs-form-control" placeholder="your@email.com" />
                    <span asp-validation-for="Email" class="text-danger small"></span>
                </div>
                <div class="mb-3">
                    <label asp-for="PhoneNumber" class="bs-label"></label>
                    <input asp-for="PhoneNumber" class="form-control bs-form-control" placeholder="+7 (900) 000-00-00" />
                    <span asp-validation-for="PhoneNumber" class="text-danger small"></span>
                </div>
                <div class="mb-3">
                    <label asp-for="Password" class="bs-label"></label>
                    <input asp-for="Password" class="form-control bs-form-control" placeholder="Минимум 6 символов" />
                    <span asp-validation-for="Password" class="text-danger small"></span>
                </div>
                <div class="mb-4">
                    <label asp-for="ConfirmPassword" class="bs-label"></label>
                    <input asp-for="ConfirmPassword" class="form-control bs-form-control" placeholder="Повторите пароль" />
                    <span asp-validation-for="ConfirmPassword" class="text-danger small"></span>
                </div>
                <button type="submit" class="btn bs-btn-gold w-100 mb-3">Создать аккаунт</button>
            </form>

            <p class="text-center text-muted small mb-0">
                Уже есть аккаунт?
                <a asp-action="Login" class="text-gold text-decoration-none">Войти</a>
            </p>
        </div>
    </div>
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <partial name="_ValidationScriptsPartial" />
</body>
</html>
