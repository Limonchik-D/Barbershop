@model LoginViewModel
@{
    ViewData["Title"] = "Вход";
    Layout = null;
}
<!DOCTYPE html>
<html lang="ru">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Вход — BarberShop</title>
    <script type="importmap"></script>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body class="bs-body bs-auth-wrapper">
    <div class="container d-flex justify-content-center align-items-center" style="min-height:100vh">
        <div class="bs-auth-card">
            <div class="text-center mb-4">
                <a asp-controller="Home" asp-action="Index" class="text-decoration-none">
                    <h3 class="text-gold fw-bold"><i class="bi bi-scissors me-2"></i>BarberShop</h3>
                </a>
                <p class="text-muted mt-1">Войдите в свой аккаунт</p>
            </div>

            <form asp-action="Login" method="post">
                <input type="hidden" asp-for="ReturnUrl" />
                <div asp-validation-summary="ModelOnly" class="alert alert-danger py-2 small"></div>

                <div class="mb-3">
                    <label asp-for="Email" class="bs-label"></label>
                    <input asp-for="Email" class="form-control bs-form-control" placeholder="your@email.com" />
                    <span asp-validation-for="Email" class="text-danger small"></span>
                </div>
                <div class="mb-3">
                    <label asp-for="Password" class="bs-label"></label>
                    <input asp-for="Password" class="form-control bs-form-control" placeholder="••••••••" />
                    <span asp-validation-for="Password" class="text-danger small"></span>
                </div>
                <div class="mb-3 form-check">
                    <input asp-for="RememberMe" class="form-check-input" />
                    <label asp-for="RememberMe" class="form-check-label text-muted small"></label>
                </div>
                <button type="submit" class="btn bs-btn-gold w-100 mb-3">Войти</button>
            </form>

            <p class="text-center text-muted small mb-0">
                Нет аккаунта?
                <a asp-action="Register" class="text-gold text-decoration-none">Зарегистрироваться</a>
            </p>
        </div>
    </div>
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <partial name="_ValidationScriptsPartial" />
</body>
</html>
