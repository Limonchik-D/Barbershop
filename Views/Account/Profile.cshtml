@model ProfileViewModel
@{
    ViewData["Title"] = "Мой профиль";
}

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="bs-card p-4">
                <h4 class="text-white mb-4"><i class="bi bi-person-circle text-gold me-2"></i>Мой профиль</h4>
                <form asp-action="Profile" method="post">
                    <div asp-validation-summary="ModelOnly" class="alert alert-danger py-2 small"></div>
                    <div class="row g-3 mb-3">
                        <div class="col-6">
                            <label asp-for="FirstName" class="bs-label"></label>
                            <input asp-for="FirstName" class="form-control bs-form-control" />
                            <span asp-validation-for="FirstName" class="text-danger small"></span>
                        </div>
                        <div class="col-6">
                            <label asp-for="LastName" class="bs-label"></label>
                            <input asp-for="LastName" class="form-control bs-form-control" />
                            <span asp-validation-for="LastName" class="text-danger small"></span>
                        </div>
                    </div>
                    <div class="mb-3">
                        <label asp-for="Email" class="bs-label"></label>
                        <input asp-for="Email" class="form-control bs-form-control" readonly />
                    </div>
                    <div class="mb-3">
                        <label asp-for="PhoneNumber" class="bs-label"></label>
                        <input asp-for="PhoneNumber" class="form-control bs-form-control" />
                        <span asp-validation-for="PhoneNumber" class="text-danger small"></span>
                    </div>
                    <div class="mb-4">
                        <label asp-for="DateOfBirth" class="bs-label"></label>
                        <input asp-for="DateOfBirth" type="date" class="form-control bs-form-control" />
                    </div>
                    <button type="submit" class="btn bs-btn-gold w-100">Сохранить</button>
                </form>
            </div>

            <div class="text-center mt-4">
                <a asp-action="MyAppointments" class="btn bs-btn-outline-gold">
                    <i class="bi bi-calendar2-check me-2"></i>Мои записи
                </a>
            </div>
        </div>
    </div>
</div>

@section Scripts { <partial name="_ValidationScriptsPartial" /> }
