@model BookAppointmentViewModel
@{
    ViewData["Title"] = "Запись на услугу";
}

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-lg-8">
            <h3 class="text-white mb-1"><i class="bi bi-calendar-plus text-gold me-2"></i>Запись на услугу</h3>
            <p class="text-muted mb-4">Заполните форму и выберите удобное время</p>

            <form asp-action="Book" method="post" id="bookingForm">
                <div asp-validation-summary="ModelOnly" class="alert alert-danger py-2 small"></div>

                <div class="bs-card p-4 mb-4">
                    <h6 class="text-gold mb-3"><i class="bi bi-1-circle me-2"></i>Выберите услугу и мастера</h6>
                    <div class="row g-3">
                        <div class="col-md-6">
                            <label asp-for="ServiceId" class="bs-label"></label>
                            <select asp-for="ServiceId" asp-items="Model.Services"
                                    class="form-select bs-form-select" id="serviceSelect">
                                <option value="">— Выберите услугу —</option>
                            </select>
                            <span asp-validation-for="ServiceId" class="text-danger small"></span>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="BarberId" class="bs-label"></label>
                            <select asp-for="BarberId" asp-items="Model.Barbers"
                                    class="form-select bs-form-select" id="barberSelect">
                                <option value="">— Выберите мастера —</option>
                            </select>
                            <span asp-validation-for="BarberId" class="text-danger small"></span>
                        </div>
                    </div>
                </div>

                <div class="bs-card p-4 mb-4">
                    <h6 class="text-gold mb-3"><i class="bi bi-2-circle me-2"></i>Выберите дату и время</h6>
                    <div class="row g-3">
                        <div class="col-md-5">
                            <label asp-for="AppointmentDate" class="bs-label"></label>
                            <input asp-for="AppointmentDate" type="date" class="form-control bs-form-control"
                                   id="dateInput"
                                   min="@DateTime.Today.AddDays(1).ToString("yyyy-MM-dd")"
                                   max="@DateTime.Today.AddDays(60).ToString("yyyy-MM-dd")" />
                            <span asp-validation-for="AppointmentDate" class="text-danger small"></span>
                        </div>
                        <div class="col-12">
                            <label class="bs-label">Доступное время</label>
                            <div id="slotsContainer" class="mt-1">
                                <p class="text-muted small">Выберите услугу, мастера и дату для отображения слотов</p>
                            </div>
                            <input type="hidden" asp-for="StartTime" id="startTimeInput" />
                            <span asp-validation-for="StartTime" class="text-danger small"></span>
                        </div>
                    </div>
                </div>

                <div class="bs-card p-4 mb-4">
                    <h6 class="text-gold mb-3"><i class="bi bi-3-circle me-2"></i>Комментарий (необязательно)</h6>
                    <textarea asp-for="Notes" class="form-control bs-form-control" rows="3"
                              placeholder="Пожелания или дополнительная информация..."></textarea>
                </div>

                <button type="submit" class="btn bs-btn-gold w-100 btn-lg" id="submitBtn" disabled>
                    <i class="bi bi-check2-circle me-2"></i>Подтвердить запись
                </button>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        const serviceSelect = document.getElementById('serviceSelect');
        const barberSelect = document.getElementById('barberSelect');
        const dateInput = document.getElementById('dateInput');
        const slotsContainer = document.getElementById('slotsContainer');
        const startTimeInput = document.getElementById('startTimeInput');
        const submitBtn = document.getElementById('submitBtn');

        function loadSlots() {
            const serviceId = serviceSelect.value;
            const barberId = barberSelect.value;
            const date = dateInput.value;
            if (!serviceId || !barberId || !date) {
                slotsContainer.innerHTML = '<p class="text-muted small">Выберите услугу, мастера и дату</p>';
                startTimeInput.value = '';
                submitBtn.disabled = true;
                return;
            }
            slotsContainer.innerHTML = '<div class="text-muted small"><i class="bi bi-arrow-repeat me-1"></i>Загружаем слоты...</div>';
            fetch(`/Appointments/GetAvailableSlots?barberId=${barberId}&date=${date}&serviceId=${serviceId}`)
                .then(r => r.json())
                .then(slots => {
                    if (!slots.length) {
                        slotsContainer.innerHTML = '<p class="text-warning small"><i class="bi bi-exclamation-triangle me-1"></i>Нет свободного времени на этот день</p>';
                        startTimeInput.value = '';
                        submitBtn.disabled = true;
                        return;
                    }
                    slotsContainer.innerHTML = slots.map(s =>
                        `<span class="bs-slot" data-time="${s}" onclick="selectSlot(this)">${s}</span>`
                    ).join('');
                    startTimeInput.value = '';
                    submitBtn.disabled = true;
                });
        }

        function selectSlot(el) {
            document.querySelectorAll('.bs-slot').forEach(s => s.classList.remove('selected'));
            el.classList.add('selected');
            startTimeInput.value = el.dataset.time;
            submitBtn.disabled = false;
        }

        serviceSelect.addEventListener('change', loadSlots);
        barberSelect.addEventListener('change', loadSlots);
        dateInput.addEventListener('change', loadSlots);
    </script>
}
