@model List<(ApplicationUser User, IList<string> Roles)>
@{
    ViewData["Title"] = "Пользователи";
    var allRoles = ViewBag.AllRoles as string[] ?? [];
    var roleLabels = new Dictionary<string, string>
    {
        ["Admin"]   = "badge-cancelled",
        ["Manager"] = "badge-confirmed",
        ["Barber"]  = "badge-pending",
        ["Client"]  = "badge-completed"
    };
}

<!-- Фильтры -->
<form method="get" class="admin-card p-3 mb-4">
    <div class="row g-3 align-items-end">
        <div class="col-md-5">
            <label class="bs-label">Поиск</label>
            <input type="text" name="search" class="form-control bs-form-control form-control-sm"
                   placeholder="Имя или email..." value="@ViewBag.CurrentSearch" />
        </div>
        <div class="col-md-3">
            <label class="bs-label">Роль</label>
            <select name="role" class="form-select bs-form-select form-select-sm">
                <option value="">Все роли</option>
                @foreach (var r in allRoles)
                {
                    var isRoleSelected = (string?)ViewBag.CurrentRole == r;
                    <option value="@r" selected="@isRoleSelected">@r</option>
                }
            </select>
        </div>
        <div class="col-md-4 d-flex gap-2">
            <button type="submit" class="btn btn-sm bs-btn-gold flex-fill">Фильтр</button>
            <a asp-action="Index" class="btn btn-sm btn-outline-secondary">Сброс</a>
        </div>
    </div>
</form>

<div class="d-flex justify-content-between align-items-center mb-3">
    <h6 class="text-white mb-0">Найдено: @Model.Count</h6>
</div>

<div class="admin-card">
    <div class="table-responsive">
        <table class="table bs-table mb-0" style="font-size:.875rem">
            <thead>
                <tr>
                    <th>Пользователь</th>
                    <th>Email</th>
                    <th>Телефон</th>
                    <th>Роли</th>
                    <th>Статус</th>
                    <th>Дата регистрации</th>
                    <th></th>
                </tr>
            </thead>
            <tbody>
                @foreach (var (user, roles) in Model)
                {
                    <tr>
                        <td class="text-white">@user.FullName</td>
                        <td class="text-muted">@user.Email</td>
                        <td class="text-muted">@user.PhoneNumber</td>
                        <td>
                            @foreach (var role in roles)
                            {
                                var cls = roleLabels.TryGetValue(role, out var c) ? c : "badge-noshow";
                                <span class="badge rounded-pill px-2 me-1 @cls" style="font-size:.7rem">@role</span>
                            }
                        </td>
                        <td>
                            @if (user.IsActive)
                            {
                                <span class="badge badge-completed rounded-pill px-2" style="font-size:.7rem">Активен</span>
                            }
                            else
                            {
                                <span class="badge badge-cancelled rounded-pill px-2" style="font-size:.7rem">Неактивен</span>
                            }
                        </td>
                        <td class="text-muted">@user.CreatedAt.ToString("dd.MM.yyyy")</td>
                        <td>
                            <a asp-action="Edit" asp-route-id="@user.Id"
                               class="btn btn-sm btn-outline-secondary">
                                <i class="bi bi-pencil"></i>
                            </a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
