@model ApplicationUser
@{
    ViewData["Title"] = "Редактировать пользователя";
    var allRoles = ViewBag.AllRoles as string[] ?? [];
    var userRoles = ViewBag.UserRoles as IList<string> ?? new List<string>();
}

<div class="row justify-content-center">
    <div class="col-md-6">
        <div class="admin-card p-4">
            <div class="d-flex align-items-center gap-3 mb-4">
                <a asp-action="Index" class="btn btn-sm btn-outline-secondary"><i class="bi bi-arrow-left"></i></a>
                <div>
                    <h5 class="text-white mb-0">@Model.FullName</h5>
                    <div class="text-muted small">@Model.Email</div>
                </div>
            </div>

            <form asp-action="Edit" asp-route-id="@Model.Id" method="post">
                <div class="mb-4">
                    <label class="bs-label">Роли пользователя</label>
                    <div class="p-3" style="background:var(--bs-dark-card2);border-radius:8px;border:1px solid var(--bs-dark-border)">
                        @foreach (var role in allRoles)
                        {
                            <div class="form-check mb-2">
                                <input class="form-check-input" type="checkbox" name="roles"
                                       value="@role" id="role_@role"
                                       @(userRoles.Contains(role) ? "checked" : "") />
                                <label class="form-check-label text-white" for="role_@role">@role</label>
                            </div>
                        }
                    </div>
                </div>
                <div class="mb-4">
                    <div class="form-check">
                        <input type="checkbox" name="isActive" value="true" class="form-check-input"
                               id="isActiveCheck" @(Model.IsActive ? "checked" : "") />
                        <input type="hidden" name="isActive" value="false" />
                        <label class="form-check-label text-white" for="isActiveCheck">Активен</label>
                    </div>
                </div>
                <div class="d-flex gap-2">
                    <button type="submit" class="btn bs-btn-gold">Сохранить</button>
                    <a asp-action="Index" class="btn btn-outline-secondary">Отмена</a>
                    @if (Model.IsActive)
                    {
                        <form asp-action="Deactivate" asp-route-id="@Model.Id" method="post" class="ms-auto"
                              onsubmit="return confirm('Деактивировать пользователя?')">
                            <button type="submit" class="btn btn-outline-danger btn-sm">
                                <i class="bi bi-person-x me-1"></i>Деактивировать
                            </button>
                        </form>
                    }
                </div>
            </form>
        </div>
    </div>
</div>
