@model List<Service>
@{
    ViewData["Title"] = "Услуги";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h5 class="text-white mb-0">Список услуг</h5>
        <div class="text-muted small">Всего: @Model.Count</div>
    </div>
    <div class="d-flex gap-2">
        <a asp-action="Categories" class="btn btn-sm btn-outline-secondary">
            <i class="bi bi-tags me-1"></i>Категории
        </a>
        <a asp-action="Create" class="btn btn-sm bs-btn-gold">
            <i class="bi bi-plus-lg me-1"></i>Добавить
        </a>
    </div>
</div>

<div class="admin-card">
    <div class="table-responsive">
        <table class="table bs-table mb-0">
            <thead>
                <tr>
                    <th>#</th>
                    <th>Название</th>
                    <th>Категория</th>
                    <th>Длительность</th>
                    <th>Цена</th>
                    <th>Статус</th>
                    <th></th>
                </tr>
            </thead>
            <tbody>
                @foreach (var svc in Model)
                {
                    <tr>
                        <td class="text-muted">@svc.Id</td>
                        <td class="text-white">@svc.Name</td>
                        <td class="text-muted">@svc.Category.Name</td>
                        <td class="text-muted">@svc.Duration мин</td>
                        <td class="text-gold">@svc.Price.ToString("N0") ₽</td>
                        <td>
                            @if (svc.IsActive)
                            {
                                <span class="badge badge-completed rounded-pill px-2">Активна</span>
                            }
                            else
                            {
                                <span class="badge badge-cancelled rounded-pill px-2">Отключена</span>
                            }
                        </td>
                        <td class="text-end">
                            <a asp-action="Edit" asp-route-id="@svc.Id"
                               class="btn btn-sm btn-outline-secondary me-1">
                                <i class="bi bi-pencil"></i>
                            </a>
                            <form asp-action="Delete" asp-route-id="@svc.Id" method="post" class="d-inline"
                                  onsubmit="return confirm('Деактивировать услугу?')">
                                <button type="submit" class="btn btn-sm btn-outline-danger">
                                    <i class="bi bi-eye-slash"></i>
                                </button>
                            </form>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
