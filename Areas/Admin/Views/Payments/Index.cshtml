@model List<Payment>
@{
    ViewData["Title"] = "Оплаты";
    var methodLabels = new Dictionary<PaymentMethod, string>
    {
        [PaymentMethod.Cash]   = "Наличные",
        [PaymentMethod.Card]   = "Карта",
        [PaymentMethod.Online] = "Онлайн"
    };
}

<!-- Фильтры -->
<form method="get" class="admin-card p-3 mb-4">
    <div class="row g-3 align-items-end">
        <div class="col-md-3">
            <label class="bs-label">Статус</label>
            <select name="status" class="form-select bs-form-select form-select-sm">
                <option value="">Все</option>
                @{ var curPayStatus = (string?)ViewBag.CurrentStatus; }
                <option value="Paid"     selected="@(curPayStatus == "Paid")"    >Оплачено</option>
                <option value="Pending"  selected="@(curPayStatus == "Pending")" >Ожидает</option>
                <option value="Refunded" selected="@(curPayStatus == "Refunded")">Возврат</option>
            </select>
        </div>
        <div class="col-md-3">
            <label class="bs-label">С даты</label>
            <input type="date" name="dateFrom" class="form-control bs-form-control form-control-sm"
                   value="@ViewBag.DateFrom" />
        </div>
        <div class="col-md-3">
            <label class="bs-label">По дату</label>
            <input type="date" name="dateTo" class="form-control bs-form-control form-control-sm"
                   value="@ViewBag.DateTo" />
        </div>
        <div class="col-md-3 d-flex gap-2">
            <button type="submit" class="btn btn-sm bs-btn-gold flex-fill">Фильтр</button>
            <a asp-action="Index" class="btn btn-sm btn-outline-secondary">Сброс</a>
        </div>
    </div>
</form>

<!-- Итого -->
<div class="row g-3 mb-4">
    <div class="col-md-4">
        <div class="stat-card">
            <div class="text-muted small mb-1">Итого оплачено</div>
            <div class="text-gold fw-bold fs-4">@((ViewBag.TotalPaid as decimal? ?? 0m).ToString("N0")) ₽</div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="stat-card">
            <div class="text-muted small mb-1">Записей в выборке</div>
            <div class="text-white fw-bold fs-4">@Model.Count</div>
        </div>
    </div>
</div>

<div class="admin-card">
    <div class="table-responsive">
        <table class="table bs-table mb-0" style="font-size:.875rem">
            <thead>
                <tr>
                    <th>#</th>
                    <th>Клиент</th>
                    <th>Услуга</th>
                    <th>Мастер</th>
                    <th>Сумма</th>
                    <th>Способ</th>
                    <th>Дата оплаты</th>
                    <th>Статус</th>
                    <th></th>
                </tr>
            </thead>
            <tbody>
                @foreach (var p in Model)
                {
                    <tr>
                        <td class="text-muted">@p.Id</td>
                        <td class="text-white">@p.Appointment.Client.FullName</td>
                        <td class="text-muted">@p.Appointment.Service.Name</td>
                        <td class="text-muted">@p.Appointment.Barber.FullName</td>
                        <td class="text-gold fw-bold">@p.Amount.ToString("N0") ₽</td>
                        <td class="text-muted">
                            @(methodLabels.TryGetValue(p.Method, out var ml) ? ml : p.Method.ToString())
                        </td>
                        <td class="text-muted">@p.PaidAt?.ToString("dd.MM.yyyy HH:mm")</td>
                        <td>
                            @if (p.Status == PaymentStatus.Paid)
                            {
                                <span class="badge badge-completed rounded-pill px-2" style="font-size:.7rem">Оплачено</span>
                            }
                            else if (p.Status == PaymentStatus.Refunded)
                            {
                                <span class="badge badge-cancelled rounded-pill px-2" style="font-size:.7rem">Возврат</span>
                            }
                            else
                            {
                                <span class="badge badge-pending rounded-pill px-2" style="font-size:.7rem">Ожидает</span>
                            }
                        </td>
                        <td>
                            @if (p.Status == PaymentStatus.Paid && User.IsInRole("Admin"))
                            {
                                <form asp-action="Refund" asp-route-id="@p.Id" method="post"
                                      onsubmit="return confirm('Оформить возврат?')">
                                    <button type="submit" class="btn btn-sm btn-outline-warning">
                                        <i class="bi bi-arrow-counterclockwise"></i>
                                    </button>
                                </form>
                            }
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
